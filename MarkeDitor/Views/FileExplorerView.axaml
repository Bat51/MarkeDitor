<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="using:MarkeDitor.Models"
             xmlns:vm="using:MarkeDitor.ViewModels"
             x:Class="MarkeDitor.Views.FileExplorerView"
             x:DataType="vm:FileExplorerViewModel">
    <Grid Background="{DynamicResource AppBackgroundBrush}" RowDefinitions="Auto,*">
        <TextBlock Name="FolderHeader" Grid.Row="0"
                   Text="Explorer" FontWeight="SemiBold"
                   Padding="12,8" Foreground="{DynamicResource AppForegroundBrush}"/>

        <TreeView Name="FileTree" Grid.Row="1"
                  Background="Transparent"
                  Foreground="{DynamicResource AppForegroundBrush}"
                  ItemsSource="{Binding Items}"
                  DoubleTapped="OnFileTreeDoubleTapped">
            <TreeView.ItemTemplate>
                <TreeDataTemplate ItemsSource="{Binding Children}" DataType="models:FileItem">
                    <TextBlock Text="{Binding Name}"/>
                </TreeDataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>
    </Grid>
</UserControl>
